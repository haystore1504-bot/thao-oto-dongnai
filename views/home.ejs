<!DOCTYPE html>
<html lang="vi">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/header') %>

<section class="hero">
  <% if (settings.hero_slides && settings.hero_slides.length) { %>
  <div class="hero-carousel" data-interval="3000">
    <% settings.hero_slides.forEach((slide, i) => { %>
      <div class="hero-slide <%= i === 0 ? 'active' : '' %>" style="background-image:url('<%= slide.url %>')"></div>
    <% }) %>
  </div>
  <% } %>
  <div class="container hero-inner">
    <h1>Showroom xe ô tô đã sử dụng<br/>uy tín tại Đồng Nai</h1>
    <p>Thảo Ô Tô Đồng Nai - Cam kết xe chất lượng, giá tốt, hỗ trợ trả góp, giấy tờ minh bạch.</p>
    <div class="hero-actions">
      <a href="/xe" class="btn-action btn-action-buy">🚗 Mua xe</a>
      <a href="/ban-xe" class="btn-action btn-action-sell">💰 Bán xe</a>
    </div>
  </div>
</section>

<% if (featuredCars.length) { %>
<section class="container section">
  <h2 class="section-title">Xe nổi bật</h2>
  <div class="car-grid">
    <% featuredCars.forEach(car => { %>
      <%- include('partials/car-card', { car }) %>
    <% }) %>
  </div>
</section>
<% } %>

<section class="container section">
  <h2 class="section-title">Xe mới cập nhật</h2>
  <% if (latestCars.length) { %>
    <div class="car-grid">
      <% latestCars.forEach(car => { %>
        <%- include('partials/car-card', { car }) %>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-text">Chưa có xe nào được cập nhật.</p>
  <% } %>
  <div class="text-center">
    <a href="/xe" class="btn-secondary">Xem tất cả xe</a>
  </div>
</section>

<%- include('partials/testimonials-slider', { testimonials }) %>

<%- include('partials/footer') %>
<script src="/js/hero-carousel.js"></script>
<script src="/js/testimonials-slider.js"></script>
</body>
</html>
