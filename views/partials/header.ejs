<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <% if (settings.logo_url) { %>
        <img src="<%= settings.logo_url %>" alt="Thảo Ô Tô Đồng Nai" class="logo-icon logo-icon-uploaded" />
      <% } else { %>
        <img src="/images/logo.svg" alt="" class="logo-icon" />
        <span class="logo-words">
          <span class="logo-mark">THẢO</span>
          <span class="logo-text">Ô TÔ ĐỒNG NAI</span>
        </span>
      <% } %>
    </a>
    <nav class="main-nav">
      <a href="/">Trang chủ</a>
      <a href="/xe">Mua xe</a>
      <a href="/ban-xe">Bán xe</a>
      <a href="/lien-he">Liên hệ</a>
      <% if (isAdmin) { %>
        <a href="/admin" class="btn-admin">Quản trị</a>
      <% } %>
    </nav>
    <a href="tel:<%= settings.hotline.replace(/\D/g, '') %>" class="btn-hotline">📞 Gọi ngay: <%= settings.hotline %></a>
  </div>
</header>
