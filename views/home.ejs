<!DOCTYPE html>
<html lang="vi">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/header') %>

<section class="hero">
  <div class="container hero-inner">
    <h1>Showroom xe ô tô đã sử dụng<br/>uy tín tại Đồng Nai</h1>
    <p>Thảo Ô Tô Đồng Nai - Cam kết xe chất lượng, giá tốt, hỗ trợ trả góp, giấy tờ minh bạch.</p>
    <a href="/xe" class="btn-primary">Xem xe đang bán</a>
  </div>
</section>

<% if (featuredCars.length) { %>
<section class="container section">
  <h2 class="section-title">Xe nổi bật</h2>
  <div class="car-grid">
    <% featuredCars.forEach(car => { %>
      <%- include('partials/car-card', { car }) %>
    <% }) %>
  </div>
</section>
<% } %>

<section class="container section">
  <h2 class="section-title">Xe mới cập nhật</h2>
  <% if (latestCars.length) { %>
    <div class="car-grid">
      <% latestCars.forEach(car => { %>
        <%- include('partials/car-card', { car }) %>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-text">Chưa có xe nào được cập nhật.</p>
  <% } %>
  <div class="text-center">
    <a href="/xe" class="btn-secondary">Xem tất cả xe</a>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
